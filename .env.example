POSTGRES_USER=repair
POSTGRES_PASSWORD=repair
POSTGRES_DB=repair_estimator
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Blueprint upload - API ключи для распознавания чертежей (опциональные)
# Gemini API - БЕСПЛАТНО (1500 запросов/день)
# Получить на: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Claude API - платно, если у вас уже есть ключ
ANTHROPIC_API_KEY=

# Ollama - для локального распознавания (бесплатно, офлайн)
OLLAMA_BASE_URL=http://localhost:11434
