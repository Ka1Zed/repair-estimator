POSTGRES_USER=repair
POSTGRES_PASSWORD=repair
POSTGRES_DB=repair_estimator
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Ходить ли в живой парсер материалов при расчёте сметы.
# true (по умолчанию) — для локалки: парсер работает с российского IP.
# false — для прод-сервера в дата-центре: расчёт берёт только кэш + seed
# (российские сайты отдают 403 на датацентровый IP). Кэш наполняет
# `python -m app.manage update_prices`, запускаемый с российского IP.
PARSER_LIVE_FETCH=true

# Публичный домен для Caddy и автоматического HTTPS (Let's Encrypt).
# Пусто/не задан — Caddy слушает :80 без TLS (локальный режим).
# На сервере без своего домена удобно sslip.io: <ip>.sslip.io резолвится в
# этот IP без регистрации, напр. PUBLIC_HOST=35.254.13.119.sslip.io
# (нужен открытый порт 443 в фаерволе). Полный гайд — docs/https-setup.md.
PUBLIC_HOST=

# Голый IP сервера (без sslip.io-имени). Нужен только для того, чтобы Caddy
# явно редиректил заход по IP на HTTPS-домен PUBLIC_HOST — иначе автоматический
# редирект Caddy сохраняет исходный Host (IP), а сертификат выпущен только на
# PUBLIC_HOST, и TLS падает. Пусто — редирект по IP не настраивается.
PUBLIC_IP=

# CORS: адрес фронта, которому backend разрешает запросы.
# Нужен, только если фронт ходит на backend НЕ через свой origin (см. VITE_API_URL
# ниже) — при same-origin через Caddy/nginx браузер вообще не шлёт CORS-preflight,
# и это значение не используется.
# Локально с Vite dev (frontend/`npm run dev` на 5173 + backend на 8000 напрямую) —
# http://localhost:5173 (значение по умолчанию). С Caddy+HTTPS — тот же домен, напр.
# https://35.254.13.119.sslip.io (без порта). Без HTTPS — http://<ip>.
FRONTEND_URL=http://localhost:5173

# Адрес backend, который зашивается во frontend-бандл при сборке (docker compose).
# Пусто ИЛИ адрес без порта совпадающий с тем, откуда открыт фронт — same-origin:
# запросы идут на относительный /api того же origin, nginx/Caddy проксируют на
# backend, CORS не нужен (FRONTEND_URL выше не используется).
#  - Полный стек локально через `docker compose up` + Caddy на :80 без домена
#    (PUBLIC_HOST пуст) — VITE_API_URL=http://localhost (без порта!). Если
#    оставить http://localhost:8000 (значение для сценария ниже), фронт полезет
#    на backend напрямую в обход Caddy и упадёт с CORS — так и было при аудите
#    2026-07-13, см. память project_docker_port_8000_conflict.
#  - Fronted через Vite dev (`npm run dev` на 5173), backend отдельно на 8000 —
#    VITE_API_URL=http://localhost:8000 (значение по умолчанию ниже), CORS
#    закрывает FRONTEND_URL=http://localhost:5173 выше.
#  - Прод с Caddy+HTTPS — same-origin https-домен без порта:
#    https://35.254.13.119.sslip.io (фронт ходит на /api того же домена).
VITE_API_URL=http://localhost:8000

# Blueprint upload - API ключи для распознавания чертежей (опциональные).
# Приоритет: Claude (основной) -> Gemini (fallback) -> Ollama (локально).

# Claude API - ОСНОВНОЙ путь распознавания. Платно (предоплата), без
# бесплатного тарифа, но без квот-0 и региональных 403/gRPC-зависаний.
# Если ANTHROPIC_API_KEY задан — используется Claude; при сбое вызова
# (невалидный ключ, нет кредита, нет сети) — откат на Gemini, затем Ollama.
ANTHROPIC_API_KEY=
# Модель Claude. Дефолт claude-sonnet-5 (vision, дёшево для агентных задач);
# дешевле/быстрее — claude-haiku-4-5, точнее/дороже — claude-opus-4-8.
ANTHROPIC_MODEL=claude-sonnet-5

# Gemini API - fallback, если ANTHROPIC_API_KEY не задан. Бесплатный тариф
# очень урезан (flash ~20 запросов/сутки, pro недоступен, квота 0) и режет
# датацентровый IP по 403 — для нормальной работы нужен биллинг.
# Получить ключ: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=
# Модель Gemini. gemini-2.5-flash работает на free-tier (с лимитом),
# gemini-2.5-pro точнее, но требует подключённого биллинга.
GEMINI_MODEL=gemini-2.5-flash
# false — не использовать Gemini вообще, даже как fallback при сбое Claude.
GEMINI_ENABLED=true

# Ollama - для локального распознавания (бесплатно, офлайн)
OLLAMA_BASE_URL=http://localhost:11434

# Параметры распознавания чертежа (опциональные).
# До скольки px ужимать картинку перед отправкой в Vision-модель.
BLUEPRINT_MAX_SIDE=2048
# Таймаут ответа Vision-модели в секундах.
BLUEPRINT_TIMEOUT=90
