POSTGRES_USER=repair
POSTGRES_PASSWORD=repair
POSTGRES_DB=repair_estimator
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Blueprint upload - API ключи для распознавания чертежей (опциональные)
# Gemini API - бесплатный тариф очень урезан (flash ~20 запросов/сутки,
# pro вообще недоступен, квота 0). Для нормальной работы нужен биллинг.
# Получить ключ: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=
# Модель распознавания. gemini-2.5-flash работает на free-tier (с лимитом),
# gemini-2.5-pro точнее, но требует подключённого биллинга.
GEMINI_MODEL=gemini-2.5-flash
# false — выключить Gemini (например, чтобы использовать Claude).
GEMINI_ENABLED=true

# Claude API - платно (предоплата), без бесплатного тарифа, но без квот-0 и
# регионального gRPC-зависания. Чтобы использовать Claude вместо Gemini:
# заполни ANTHROPIC_API_KEY и поставь GEMINI_ENABLED=false.
ANTHROPIC_API_KEY=
# Модель Claude. Дешевле/быстрее: claude-sonnet-4-6 или claude-haiku-4-5.
ANTHROPIC_MODEL=claude-opus-4-8

# Ollama - для локального распознавания (бесплатно, офлайн)
OLLAMA_BASE_URL=http://localhost:11434
